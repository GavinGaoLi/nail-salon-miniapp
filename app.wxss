/* ========== 设计系统 ========== */
page {
  --color-primary: #C4A882;
  --color-primary-light: #F5F0EB;
  --color-bg: #FAFAFA;
  --color-white: #FFFFFF;
  --color-text: #1A1A1A;
  --color-text-secondary: #888888;
  --color-text-hint: #BBBBBB;
  --color-border: #F0F0F0;
  --color-success: #52C41A;
  --color-warning: #FAAD14;
  --color-error: #FF4D4F;
  --radius-card: 20rpx;
  --radius-btn: 12rpx;
  --shadow-card: 0 4rpx 16rpx rgba(0,0,0,0.04);
  --spacing: 32rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: var(--color-text);
  background: var(--color-bg);
}

/* ========== 通用组件 ========== */
.card {
  background: var(--color-white);
  border-radius: var(--radius-card);
  padding: var(--spacing);
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-secondary {
  background: var(--color-primary-light);
  color: var(--color-primary);
  border-radius: var(--radius-btn);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.text-secondary {
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.text-hint {
  color: var(--color-text-hint);
  font-size: 24rpx;
}

/* ========== 卡片列表 ========== */
.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx var(--spacing);
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
}
.list-item:last-child { border-bottom: none; }

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-text {
  color: var(--color-text-hint);
  font-size: 28rpx;
  margin-top: 16rpx;
}

/* ========== 标签 ========== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.tag-primary { background: var(--color-primary-light); color: var(--color-primary); }
.tag-success { background: #E8F5E9; color: var(--color-success); }
.tag-warning { background: #FFF3E0; color: var(--color-warning); }
