<!--客户管理页面-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <text>🔍</text>
    <input placeholder="搜索客户姓名或手机号" value="{{searchKey}}" bindinput="onSearch" />
  </view>

  <!-- 客户统计 -->
  <view class="stats-bar">
    <view class="stat-chip">
      <text class="stat-chip-value">{{customers.length}}</text>
      <text class="stat-chip-label">总客户</text>
    </view>
    <view class="stat-chip">
      <text class="stat-chip-value">{{vipCount}}</text>
      <text class="stat-chip-label">VIP客户</text>
    </view>
  </view>

  <!-- 客户列表 -->
  <view wx:if="{{filteredCustomers.length > 0}}">
    <view class="customer-card animate-in" wx:for="{{filteredCustomers}}" wx:key="id" bindtap="viewCustomer" data-id="{{item.id}}">
      <view class="customer-header">
        <view class="customer-avatar">{{item.name[0]}}</view>
        <view class="customer-main">
          <view class="customer-name-row">
            <text class="customer-name">{{item.name}}</text>
            <view wx:if="{{item.visits >= 10}}" class="vip-badge">VIP</view>
          </view>
          <text class="customer-phone">📱 {{item.phone}}</text>
        </view>
        <view class="customer-visits">
          <text class="visits-count">{{item.visits}}</text>
          <text class="visits-label">次到店</text>
        </view>
      </view>
      <view class="customer-preferences" wx:if="{{item.preferences.colors.length > 0}}">
        <text class="tag tag-primary" wx:for="{{item.preferences.colors}}" wx:for-item="color" wx:key="*this">{{color}}</text>
        <text class="tag tag-gold" wx:for="{{item.preferences.styles}}" wx:for-item="style" wx:key="*this">{{style}}</text>
      </view>
      <view class="customer-footer">
        <text class="customer-spent">累计消费 ¥{{item.totalSpent}}</text>
        <text class="customer-date">最近 {{item.lastVisit || '无记录'}}</text>
      </view>
    </view>
  </view>
  <view wx:else class="empty-state">
    <text class="empty-icon">👥</text>
    <text class="empty-text">{{searchKey ? '未找到匹配客户' : '暂无客户记录'}}</text>
  </view>

  <!-- 添加客户浮动按钮 -->
  <view class="fab" bindtap="showAddModal">
    <text>+</text>
  </view>

  <!-- 添加/编辑客户弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">{{editingId ? '编辑客户' : '添加客户'}}</view>
      
      <view class="form-group">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入客户姓名" value="{{form.name}}" bindinput="onFormInput" data-field="name" />
      </view>

      <view class="form-group">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onFormInput" data-field="phone" />
      </view>

      <view class="form-group">
        <text class="form-label">喜欢的颜色</text>
        <view class="color-options">
          <view class="color-option {{form.colors.includes(item) ? 'selected' : ''}}" 
                wx:for="{{colorOptions}}" wx:key="*this"
                bindtap="toggleColor" data-color="{{item}}">
            {{item}}
          </view>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">喜欢的款式</text>
        <view class="color-options">
          <view class="color-option {{form.styles.includes(item) ? 'selected' : ''}}" 
                wx:for="{{styleOptions}}" wx:key="*this"
                bindtap="toggleStyle" data-style="{{item}}">
            {{item}}
          </view>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">甲型偏好</text>
        <picker mode="selector" range="{{nailShapeOptions}}" value="{{selectedShapeIndex}}" bindchange="onShapeSelect">
          <view class="form-picker">
            <text>{{form.nailShape || '请选择甲型'}}</text>
            <text class="arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-group">
        <text class="form-label">备注</text>
        <textarea class="form-textarea" placeholder="如过敏信息、特殊偏好等" value="{{form.notes}}" bindinput="onFormInput" data-field="notes" />
      </view>

      <view class="modal-actions">
        <button class="btn-secondary" bindtap="hideModal">取消</button>
        <button class="btn-primary" bindtap="saveCustomer">保存</button>
      </view>
    </view>
  </view>

  <!-- 客户详情弹窗 -->
  <view class="modal-mask" wx:if="{{showDetailModal}}" bindtap="hideDetailModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">客户详情</view>
      
      <view class="detail-section" wx:if="{{detailCustomer}}">
        <view class="detail-row">
          <text class="detail-label">姓名</text>
          <text class="detail-value">{{detailCustomer.name}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">手机</text>
          <text class="detail-value">{{detailCustomer.phone}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">到店次数</text>
          <text class="detail-value">{{detailCustomer.visits}} 次</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">累计消费</text>
          <text class="detail-value">¥{{detailCustomer.totalSpent}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">最近到店</text>
          <text class="detail-value">{{detailCustomer.lastVisit || '无记录'}}</text>
        </view>
        <view class="detail-row" wx:if="{{detailCustomer.preferences.colors.length > 0}}">
          <text class="detail-label">喜好颜色</text>
          <view class="detail-tags">
            <text class="tag tag-primary" wx:for="{{detailCustomer.preferences.colors}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="detail-row" wx:if="{{detailCustomer.preferences.styles.length > 0}}">
          <text class="detail-label">喜好款式</text>
          <view class="detail-tags">
            <text class="tag tag-gold" wx:for="{{detailCustomer.preferences.styles}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="detail-row" wx:if="{{detailCustomer.preferences.nailShape}}">
          <text class="detail-label">甲型</text>
          <text class="detail-value">{{detailCustomer.preferences.nailShape}}</text>
        </view>
        <view class="detail-row" wx:if="{{detailCustomer.notes}}">
          <text class="detail-label">备注</text>
          <text class="detail-value">{{detailCustomer.notes}}</text>
        </view>
      </view>

      <view class="modal-actions">
        <button class="btn-secondary" bindtap="editCustomer">编辑</button>
        <button class="btn-primary" bindtap="hideDetailModal">关闭</button>
      </view>
    </view>
  </view>
</view>
