<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索服务" bindinput="onSearch" value="{{keyword}}"/>
  </view>

  <view class="service-list">
    <view class="service-card" wx:for="{{filteredServices}}" wx:key="id" bindtap="goBook">
      <view class="sc-left">
        <view class="sc-icon-wrap" style="background:{{item.bg}}">
          <text class="sc-icon">{{item.icon}}</text>
        </view>
        <view class="sc-info">
          <text class="sc-name">{{item.name}}</text>
          <text class="sc-desc">{{item.desc}}</text>
          <text class="sc-time">约{{item.duration}}分钟</text>
        </view>
      </view>
      <view class="sc-right">
        <text class="sc-price">¥{{item.price}}</text>
        <view class="sc-book-btn">预约</view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{filteredServices.length===0}}">
    <text class="empty-text">没有找到相关服务</text>
  </view>
</view>