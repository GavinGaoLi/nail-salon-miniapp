.page { background: #FAFAFA; min-height: 100vh; padding-bottom: 120rpx; }

.tag-scroll { 
  white-space: nowrap; background: #fff; padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0; position: sticky; top: 0; z-index: 10;
}
.tag-item {
  display: inline-block; padding: 12rpx 28rpx; margin-right: 16rpx;
  border-radius: 24rpx; font-size: 26rpx; color: #888; background: #F5F5F5;
}
.tag-item.active { background: #C4A882; color: #fff; }

.waterfall { display: flex; padding: 24rpx 16rpx; gap: 16rpx; }
.waterfall-left, .waterfall-right { flex: 1; display: flex; flex-direction: column; gap: 16rpx; }

.gallery-card {
  background: #fff; border-radius: 16rpx; overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.gc-img {
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.gc-placeholder { font-size: 60rpx; }
.gc-info { padding: 16rpx 20rpx; }
.gc-title { font-size: 26rpx; color: #1A1A1A; display: block; margin-bottom: 8rpx; }
.gc-stats { display: flex; justify-content: space-between; align-items: center; }
.gc-likes { font-size: 22rpx; color: #FF6B81; }
.gc-source { font-size: 20rpx; color: #BBB; }