<view class="page">
  <!-- Banner -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">精致美甲</text>
      <text class="banner-sub">为你的指尖增添光彩</text>
      <view class="banner-btn" bindtap="goBook">立即预约</view>
    </view>
  </view>

  <!-- 热门服务 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门服务</text>
      <text class="section-more" bindtap="goService">全部 ›</text>
    </view>
    <scroll-view scroll-x class="scroll-row">
      <view class="service-card" wx:for="{{hotServices}}" wx:key="id" bindtap="goBook">
        <view class="sc-icon">{{item.icon}}</view>
        <text class="sc-name">{{item.name}}</text>
        <text class="sc-price">¥{{item.price}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 作品展示 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">精选作品</text>
    </view>
    <view class="gallery">
      <view class="gallery-item" wx:for="{{works}}" wx:key="id">
        <view class="gallery-img" style="background:{{item.bg}}"></view>
        <text class="gallery-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 店铺信息 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">关于我们</text>
    </view>
    <view class="card about">
      <text class="about-text">专注美甲艺术5年，用心打造每一份精致。采用进口甲油胶，安全无刺激。</text>
      <view class="about-stats">
        <view class="stat-item">
          <text class="stat-num">500+</text>
          <text class="stat-label">满意客户</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">5年</text>
          <text class="stat-label">专业经验</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">50+</text>
          <text class="stat-label">款式可选</text>
        </view>
      </view>
    </view>
  </view>
</view>