.page { background: #FAFAFA; min-height: 100vh; }
.summary {
  background: linear-gradient(135deg, #C4A882 0%, #D4BFA6 100%);
  padding: 60rpx 32rpx 40rpx; text-align: center;
}
.summary-label { display: block; font-size: 26rpx; color: rgba(255,255,255,0.8); margin-bottom: 12rpx; }
.summary-num { display: block; font-size: 56rpx; font-weight: 700; color: #fff; }
.section { padding: 24rpx 32rpx 0; }
.section-title { font-size: 28rpx; font-weight: 600; color: #1A1A1A; margin-bottom: 16rpx; display: block; }
.income-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.ii-customer { font-size: 28rpx; font-weight: 600; color: #1A1A1A; display: block; }
.ii-service { font-size: 24rpx; color: #888; margin-top: 4rpx; display: block; }
.ii-price { font-size: 30rpx; font-weight: 700; color: #C4A882; display: block; text-align: right; }
.ii-time { font-size: 24rpx; color: #888; margin-top: 4rpx; display: block; text-align: right; }