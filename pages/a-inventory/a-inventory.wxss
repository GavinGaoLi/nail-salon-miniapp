.page { background: #FAFAFA; min-height: 100vh; padding-bottom: 120rpx; }
.tag-scroll { white-space: nowrap; background: #fff; padding: 20rpx 32rpx; border-bottom: 1rpx solid #F0F0F0; }
.tag-item {
  display: inline-block; padding: 12rpx 28rpx; margin-right: 16rpx;
  border-radius: 24rpx; font-size: 26rpx; color: #888; background: #F5F5F5;
}
.tag-item.active { background: #C4A882; color: #fff; }

.list { padding: 24rpx 32rpx; }
.material-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.mi-name { font-size: 28rpx; font-weight: 600; color: #1A1A1A; display: block; }
.mi-category { font-size: 22rpx; color: #C4A882; background: #FDFBF8; padding: 4rpx 12rpx; border-radius: 12rpx; margin-top: 8rpx; display: inline-block; }
.mi-stock { font-size: 24rpx; color: #888; margin-top: 8rpx; display: block; }
.mi-stock.low { color: #FF4D4F; font-weight: 600; }
.mi-btn { font-size: 24rpx; color: #C4A882; padding: 8rpx 24rpx; border: 1rpx solid #C4A882; border-radius: 20rpx; }

.fab {
  position: fixed; bottom: 48rpx; right: 48rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: #C4A882; color: #fff;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(196,168,130,0.4);
}
.fab-icon { font-size: 48rpx; font-weight: 300; }

.popup-content { padding: 32rpx; }
.popup-title { font-size: 32rpx; font-weight: 600; color: #1A1A1A; display: block; margin-bottom: 24rpx; text-align: center; }
.popup-btn {
  background: #C4A882; color: #fff; border-radius: 12rpx; padding: 24rpx 0;
  text-align: center; font-size: 30rpx; font-weight: 600; margin-top: 32rpx;
}