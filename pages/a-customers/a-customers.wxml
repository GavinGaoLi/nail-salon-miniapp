<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索客户" bindinput="onSearch" value="{{keyword}}"/>
  </view>

  <view class="list">
    <view class="card customer-item" wx:for="{{customers}}" wx:key="id">
      <view class="ci-left">
        <view class="ci-avatar">
          <text class="ci-avatar-text">{{item.name[0]}}</text>
        </view>
        <view class="ci-info">
          <text class="ci-name">{{item.name}}</text>
          <text class="ci-phone">{{item.phone}}</text>
        </view>
      </view>
      <view class="ci-right">
        <text class="ci-count">{{item.visitCount}}次</text>
        <text class="ci-spent">¥{{item.totalSpent}}</text>
      </view>
    </view>
  </view>
</view>