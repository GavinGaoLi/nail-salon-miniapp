<!--个人中心页面-->
<view class="container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="profile-bg"></view>
    <view class="profile-content">
      <view class="profile-avatar">💅</view>
      <text class="profile-name">美甲时光</text>
      <text class="profile-role">店铺管理系统</text>
    </view>
  </view>

  <!-- 店铺信息 -->
  <view class="card animate-in">
    <view class="card-title">店铺信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-icon">🏪</text>
        <text class="info-label">店铺名称</text>
        <text class="info-value">美甲时光</text>
      </view>
      <view class="info-item">
        <text class="info-icon">📞</text>
        <text class="info-label">联系电话</text>
        <text class="info-value">400-888-8888</text>
      </view>
      <view class="info-item">
        <text class="info-icon">📍</text>
        <text class="info-label">店铺地址</text>
        <text class="info-value">北京市朝阳区美甲街88号</text>
      </view>
      <view class="info-item">
        <text class="info-icon">🕐</text>
        <text class="info-label">营业时间</text>
        <text class="info-value">09:00 - 21:00</text>
      </view>
    </view>
  </view>

  <!-- 美甲师管理 -->
  <view class="card animate-in">
    <view class="card-title">美甲师团队</view>
    <view class="artist-list">
      <view class="artist-card" wx:for="{{artists}}" wx:key="id">
        <view class="artist-avatar">{{item.name[0]}}</view>
        <view class="artist-info">
          <text class="artist-name">{{item.name}}</text>
          <text class="artist-specialty">{{item.specialty}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="card animate-in">
    <view class="card-title">数据管理</view>
    <view class="info-list">
      <view class="info-item clickable" bindtap="exportData">
        <text class="info-icon">📤</text>
        <text class="info-label">导出数据</text>
        <text class="info-arrow">›</text>
      </view>
      <view class="info-item clickable" bindtap="importData">
        <text class="info-icon">📥</text>
        <text class="info-label">导入数据</text>
        <text class="info-arrow">›</text>
      </view>
      <view class="info-item clickable" bindtap="clearData">
        <text class="info-icon">🗑️</text>
        <text class="info-label">清除数据</text>
        <text class="info-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 系统设置 -->
  <view class="card animate-in">
    <view class="card-title">系统设置</view>
    <view class="info-list">
      <view class="info-item clickable" bindtap="showAbout">
        <text class="info-icon">ℹ️</text>
        <text class="info-label">关于系统</text>
        <text class="info-arrow">›</text>
      </view>
      <view class="info-item clickable" bindtap="showHelp">
        <text class="info-icon">❓</text>
        <text class="info-label">使用帮助</text>
        <text class="info-arrow">›</text>
      </view>
      <view class="info-item clickable" bindtap="showFeedback">
        <text class="info-icon">💬</text>
        <text class="info-label">意见反馈</text>
        <text class="info-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">美甲时光 v1.0.0</text>
    <text class="version-copyright">© 2026 Nail Salon Mini Program</text>
  </view>
</view>
