/* 个人中心页面样式 */

/* 头部 */
.profile-header {
  position: relative;
  margin: -24rpx -24rpx 24rpx -24rpx;
  padding: 60rpx 32rpx 80rpx;
  overflow: hidden;
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #E8879B, #D4A574);
  border-radius: 0 0 40rpx 40rpx;
}

.profile-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-bottom: 16rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.profile-role {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0E0E4;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 48rpx;
  text-align: center;
}

.info-label {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.info-value {
  font-size: 28rpx;
  color: #666666;
}

.info-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

.clickable {
  cursor: pointer;
}

.clickable:active {
  background: #FFF5F7;
  margin: 0 -28rpx;
  padding: 20rpx 28rpx;
}

/* 美甲师列表 */
.artist-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.artist-card {
  display: flex;
  align-items: center;
  background: #FFF5F7;
  border-radius: 16rpx;
  padding: 20rpx;
}

.artist-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8879B, #D4A574);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.artist-info {
  flex: 1;
}

.artist-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.artist-specialty {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
  margin-top: 20rpx;
}

.version-text {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.version-copyright {
  display: block;
  font-size: 22rpx;
  color: #CCCCCC;
}
