/* 预约页面样式 */

.action-bar {
  margin-bottom: 24rpx;
}

.tab-group {
  display: flex;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(232, 135, 155, 0.15);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #E8879B, #C96B7F);
  color: #FFFFFF;
  font-weight: 500;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.date-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.date-picker .arrow {
  font-size: 20rpx;
  color: #999999;
}

.filter-clear {
  color: #E8879B;
  font-size: 26rpx;
  padding: 16rpx;
}

/* 预约卡片 */
.booking-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(232, 135, 155, 0.15);
}

.booking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0E0E4;
}

.booking-date-time {
  display: flex;
  gap: 20rpx;
}

.booking-date, .booking-time {
  font-size: 26rpx;
  color: #333333;
}

.status-badge {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-badge.confirmed {
  background: #E8F5E9;
  color: #67C23A;
}

.status-badge.pending {
  background: #FFF3E0;
  color: #E6A23C;
}

.status-badge.completed {
  background: #E3F2FD;
  color: #1976D2;
}

/* 预约详情 */
.booking-body {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #666666;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

/* 操作按钮 */
.booking-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0E0E4;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.confirm-btn {
  background: #E8F5E9;
  color: #67C23A;
}

.complete-btn {
  background: #E3F2FD;
  color: #1976D2;
}

.cancel-btn {
  background: #FFEBEE;
  color: #F56C6C;
}

/* 表单样式 */
.form-container {
  animation: fadeIn 0.3s ease-out;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #FFF5F7;
  border: 2rpx solid #F0E0E4;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 价格显示 */
.price-display {
  background: linear-gradient(135deg, #FFF5F7, #FFFFFF);
  border: 2rpx solid #F0E0E4;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-label {
  font-size: 26rpx;
  color: #666666;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #E8879B;
}

.price-duration {
  font-size: 24rpx;
  color: #999999;
}
