<view class="page">
  <view class="card detail-card">
    <view class="dc-row">
      <text class="dc-label">客户</text>
      <text class="dc-value">{{booking.customer}}</text>
    </view>
    <view class="dc-row">
      <text class="dc-label">手机号</text>
      <text class="dc-value">{{booking.phone}}</text>
    </view>
    <view class="dc-row">
      <text class="dc-label">服务项目</text>
      <text class="dc-value">{{booking.service}}</text>
    </view>
    <view class="dc-row">
      <text class="dc-label">预约日期</text>
      <text class="dc-value">{{booking.date}}</text>
    </view>
    <view class="dc-row">
      <text class="dc-label">预约时间</text>
      <text class="dc-value">{{booking.time}}</text>
    </view>
    <view class="dc-row">
      <text class="dc-label">费用</text>
      <text class="dc-value price">¥{{booking.price}}</text>
    </view>
    <view class="dc-row">
      <text class="dc-label">状态</text>
      <text class="tag {{booking.status==='confirmed'?'tag-success':'tag-warning'}}">{{booking.statusText}}</text>
    </view>
    <view class="dc-row last">
      <text class="dc-label">备注</text>
      <text class="dc-value">{{booking.note || '无'}}</text>
    </view>
  </view>

  <view class="btn-group" wx:if="{{booking.status==='pending'}}">
    <view class="btn-primary" bindtap="confirm">确认预约</view>
    <view class="btn-danger" bindtap="cancel">取消预约</view>
  </view>
</view>