.page { background: #FAFAFA; min-height: 100vh; padding-bottom: 120rpx; }

.user-card {
  background: linear-gradient(135deg, #C4A882 0%, #D4BFA6 100%);
  padding: 80rpx 40rpx 48rpx;
  display: flex; align-items: center; gap: 24rpx;
}
.avatar-placeholder {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.5);
}
.avatar-text { font-size: 40rpx; color: #fff; font-weight: 600; }
.user-name { font-size: 32rpx; font-weight: 600; color: #fff; display: block; }
.user-level { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; display: block; }

.member-card {
  background: #fff; margin: -24rpx 32rpx 0; border-radius: 16rpx;
  padding: 28rpx 32rpx; display: flex; justify-content: space-between; align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); position: relative; z-index: 1;
}
.mc-title { font-size: 26rpx; color: #888; display: block; }
.mc-balance { font-size: 40rpx; font-weight: 700; color: #C4A882; margin-top: 4rpx; display: block; }
.mc-btn { background: #C4A882; color: #fff; border-radius: 24rpx; padding: 12rpx 32rpx; font-size: 26rpx; }

.menu-card { margin: 32rpx; }
.menu-item {
  display: flex; align-items: center; padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.menu-item:last-child { border-bottom: none; }
.mi-text { flex: 1; font-size: 28rpx; color: #1A1A1A; }
.mi-badge {
  font-size: 24rpx; color: #C4A882; background: #FDFBF8;
  padding: 4rpx 16rpx; border-radius: 20rpx; margin-right: 12rpx;
}
.mi-arrow { font-size: 32rpx; color: #CCC; }