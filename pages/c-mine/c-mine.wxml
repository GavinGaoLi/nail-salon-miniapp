<view class="page">
  <!-- User Card -->
  <view class="user-card">
    <view class="avatar-placeholder">
      <text class="avatar-text">{{nickName ? nickName[0] : '?'}}</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{nickName || '点击登录'}}</text>
      <text class="user-level">普通会员</text>
    </view>
  </view>

  <!-- Member Card -->
  <view class="member-card">
    <view class="mc-info">
      <text class="mc-title">会员卡</text>
      <text class="mc-balance">¥{{balance}}</text>
    </view>
    <view class="mc-btn" bindtap="recharge">充值</view>
  </view>

  <!-- Menu -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="goOrders">
      <text class="mi-text">我的预约</text>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goReviews">
      <text class="mi-text">我的评价</text>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPoints">
      <text class="mi-text">积分</text>
      <text class="mi-badge">{{points}}分</text>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <text class="mi-text">关于我们</text>
      <text class="mi-arrow">›</text>
    </view>
  </view>
</view>