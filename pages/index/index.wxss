/* 首页样式 */

.header {
  position: relative;
  margin: -24rpx -24rpx 24rpx -24rpx;
  padding: 40rpx 32rpx 60rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #E8879B, #D4A574);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.welcome {
  display: flex;
  flex-direction: column;
}

.welcome-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.welcome-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-item {
  background: linear-gradient(135deg, #FFF5F7, #FFFFFF);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid #F0E0E4;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #E8879B;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.booking-icon { background: linear-gradient(135deg, #FFB6C1, #E8879B); }
.customer-icon { background: linear-gradient(135deg, #B5D8F7, #7BB3E0); }
.inventory-icon { background: linear-gradient(135deg, #C5E1A5, #8BC34A); }
.stats-icon { background: linear-gradient(135deg, #FFE0B2, #FFB74D); }

.action-text {
  font-size: 24rpx;
  color: #666666;
}

/* 预约列表 */
.booking-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0E0E4;
}

.booking-item:last-child {
  border-bottom: none;
}

.booking-time {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8879B;
  width: 100rpx;
}

.booking-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.booking-customer {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.booking-service {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.booking-artist {
  font-size: 24rpx;
  color: #666666;
  margin-right: 16rpx;
}

.booking-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-confirmed {
  background: #E8F5E9;
  color: #67C23A;
}

.status-pending {
  background: #FFF3E0;
  color: #E6A23C;
}

/* 最近客户 */
.recent-customer {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0E0E4;
}

.recent-customer:last-child {
  border-bottom: none;
}

.customer-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8879B, #D4A574);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.customer-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.customer-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.customer-visits {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.customer-date {
  font-size: 24rpx;
  color: #999999;
}

/* 库存预警 */
.low-stock-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0E0E4;
}

.low-stock-item:last-child {
  border-bottom: none;
}

.stock-name {
  font-size: 28rpx;
  color: #333333;
}

.stock-quantity {
  font-size: 24rpx;
  color: #F56C6C;
  font-weight: 500;
}
