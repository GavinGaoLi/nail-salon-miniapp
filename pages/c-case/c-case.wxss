.page { background: #FAFAFA; min-height: 100vh; padding-bottom: 140rpx; }

.case-header {
  background: linear-gradient(135deg, #C4A882 0%, #D4BFA6 100%);
  padding: 60rpx 32rpx 40rpx;
}
.case-title { display: block; font-size: 40rpx; font-weight: 700; color: #fff; }
.case-desc { display: block; font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

.section { padding: 24rpx 32rpx 0; }
.section-title { font-size: 28rpx; font-weight: 600; color: #1A1A1A; margin-bottom: 16rpx; display: block; }

.intro-text { font-size: 26rpx; color: #666; line-height: 1.8; }

.case-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.case-item {
  background: #fff; border-radius: 16rpx; overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.case-img { height: 280rpx; display: flex; align-items: center; justify-content: center; }
.case-img-placeholder { font-size: 40rpx; }
.case-name { padding: 16rpx 20rpx; font-size: 26rpx; color: #1A1A1A; display: block; }

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 20rpx 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}
.bottom-bar .btn-primary { margin-top: 0; }