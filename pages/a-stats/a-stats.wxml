<view class="page">
  <!-- Period Selector -->
  <view class="period-bar">
    <view class="period-item {{period==='week'?'active':''}}" bindtap="setPeriod" data-p="week">本周</view>
    <view class="period-item {{period==='month'?'active':''}}" bindtap="setPeriod" data-p="month">本月</view>
    <view class="period-item {{period==='year'?'active':''}}" bindtap="setPeriod" data-p="year">本年</view>
  </view>

  <!-- Summary -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-num">¥{{summary.income}}</text>
      <text class="stat-label">总收入</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{summary.orders}}</text>
      <text class="stat-label">总订单</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{summary.customers}}</text>
      <text class="stat-label">客户数</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">¥{{summary.avgPrice}}</text>
      <text class="stat-label">客单价</text>
    </view>
  </view>

  <!-- Top Services -->
  <view class="section">
    <text class="section-title">热门服务</text>
    <view class="card" wx:for="{{topServices}}" wx:key="name">
      <view class="ts-row">
        <text class="ts-name">{{item.name}}</text>
        <text class="ts-count">{{item.count}}次</text>
        <text class="ts-revenue">¥{{item.revenue}}</text>
      </view>
      <view class="ts-bar-bg">
        <view class="ts-bar" style="width:{{item.percent}}%"></view>
      </view>
    </view>
  </view>
</view>