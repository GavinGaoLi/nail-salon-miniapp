.page { background: #FAFAFA; min-height: 100vh; padding-bottom: 40rpx; }
.service-list { padding: 24rpx 32rpx; }
.service-item { margin-bottom: 20rpx; }
.si-top { display: flex; align-items: center; margin-bottom: 20rpx; }
.si-icon-wrap {
  width: 80rpx; height: 80rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center; margin-right: 20rpx;
}
.si-icon { font-size: 36rpx; }
.si-info { flex: 1; }
.si-name { font-size: 30rpx; font-weight: 600; color: #1A1A1A; display: block; }
.si-desc { font-size: 24rpx; color: #888; margin-top: 4rpx; display: block; }
.si-time { font-size: 22rpx; color: #BBB; margin-top: 4rpx; display: block; }
.si-price { font-size: 32rpx; font-weight: 700; color: #C4A882; }
.si-actions { display: flex; gap: 16rpx; }
.si-btn {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 12rpx;
  font-size: 26rpx;
}
.si-btn.case { background: #F5F0EB; color: #C4A882; }
.si-btn.book { background: #C4A882; color: #fff; }