/* 财务统计页面样式 */

/* 日期范围选择 */
.date-range-bar {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(232, 135, 155, 0.15);
}

.range-tabs {
  display: flex;
  background: #FFF5F7;
  border-radius: 30rpx;
  padding: 6rpx;
}

.range-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.3s;
}

.range-tab.active {
  background: #E8879B;
  color: #FFFFFF;
  font-weight: 500;
}

.custom-date {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  gap: 16rpx;
}

.date-btn {
  background: #FFF5F7;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #333333;
}

.date-separator {
  font-size: 24rpx;
  color: #999999;
}

/* 总览卡片 */
.overview-card {
  background: linear-gradient(135deg, #E8879B, #D4A574);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #FFFFFF;
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 30rpx;
  font-weight: 600;
}

.overview-date {
  font-size: 24rpx;
  opacity: 0.85;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.overview-item {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.overview-icon {
  font-size: 32rpx;
  display: block;
  margin-bottom: 8rpx;
}

.overview-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.overview-label {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
}

.profit-rate {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profit-rate-label {
  font-size: 24rpx;
  opacity: 0.85;
  min-width: 80rpx;
}

.profit-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.profit-bar-fill {
  height: 100%;
  background: #FFFFFF;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.profit-rate-value {
  font-size: 26rpx;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

/* 每日明细 */
.daily-item {
  background: #FFF5F7;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.daily-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #F0E0E4;
}

.daily-date {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.daily-count {
  font-size: 24rpx;
  color: #999999;
}

.daily-body {
  display: flex;
  gap: 16rpx;
}

.daily-stat {
  flex: 1;
  text-align: center;
}

.daily-stat-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.daily-stat-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.profit-text {
  color: #E8879B !important;
}

/* 热门服务 */
.service-rank {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0E0E4;
}

.service-rank:last-child {
  border-bottom: none;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F0E0E4;
  color: #666666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.rank-badge.top {
  background: linear-gradient(135deg, #E8879B, #D4A574);
  color: #FFFFFF;
}

.rank-info {
  flex: 1;
}

.rank-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.rank-count {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.rank-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8879B;
}

/* 美甲师业绩 */
.artist-stat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0E0E4;
}

.artist-stat:last-child {
  border-bottom: none;
}

.artist-info {
  display: flex;
  align-items: center;
}

.artist-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8879B, #D4A574);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.artist-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.artist-data {
  display: flex;
  gap: 32rpx;
}

.artist-data-item {
  text-align: center;
}

.artist-data-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #E8879B;
}

.artist-data-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
}
