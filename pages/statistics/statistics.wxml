<!--财务统计页面-->
<view class="container">
  <!-- 日期范围选择 -->
  <view class="date-range-bar">
    <view class="range-tabs">
      <view class="range-tab {{dateRange === 'today' ? 'active' : ''}}" bindtap="setDateRange" data-range="today">今日</view>
      <view class="range-tab {{dateRange === 'week' ? 'active' : ''}}" bindtap="setDateRange" data-range="week">本周</view>
      <view class="range-tab {{dateRange === 'month' ? 'active' : ''}}" bindtap="setDateRange" data-range="month">本月</view>
      <view class="range-tab {{dateRange === 'custom' ? 'active' : ''}}" bindtap="setDateRange" data-range="custom">自定义</view>
    </view>
    <view wx:if="{{dateRange === 'custom'}}" class="custom-date">
      <picker mode="date" value="{{startDate}}" bindchange="onStartDate">
        <view class="date-btn">{{startDate}}</view>
      </picker>
      <text class="date-separator">至</text>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDate">
        <view class="date-btn">{{endDate}}</view>
      </picker>
    </view>
  </view>

  <!-- 总览卡片 -->
  <view class="overview-card animate-in">
    <view class="overview-header">
      <text class="overview-title">📊 数据概览</text>
      <text class="overview-date">{{dateRangeText}}</text>
    </view>
    <view class="overview-grid">
      <view class="overview-item">
        <text class="overview-icon">💰</text>
        <text class="overview-value">¥{{stats.totalIncome}}</text>
        <text class="overview-label">总收入</text>
      </view>
      <view class="overview-item">
        <text class="overview-icon">📦</text>
        <text class="overview-value">¥{{stats.totalCost}}</text>
        <text class="overview-label">总成本</text>
      </view>
      <view class="overview-item profit">
        <text class="overview-icon">📈</text>
        <text class="overview-value">¥{{stats.totalProfit}}</text>
        <text class="overview-label">总利润</text>
      </view>
      <view class="overview-item">
        <text class="overview-icon">🧾</text>
        <text class="overview-value">{{stats.totalOrders}}</text>
        <text class="overview-label">订单数</text>
      </view>
    </view>
    <view class="profit-rate" wx:if="{{stats.totalIncome > 0}}">
      <text class="profit-rate-label">利润率</text>
      <view class="profit-bar">
        <view class="profit-bar-fill" style="width: {{stats.profitRate}}%"></view>
      </view>
      <text class="profit-rate-value">{{stats.profitRate}}%</text>
    </view>
  </view>

  <!-- 每日明细 -->
  <view class="card animate-in">
    <view class="card-title">每日明细</view>
    <view wx:if="{{dailyStats.length > 0}}">
      <view class="daily-item" wx:for="{{dailyStats}}" wx:key="date">
        <view class="daily-header">
          <text class="daily-date">📅 {{item.date}}</text>
          <text class="daily-count">{{item.count}} 单</text>
        </view>
        <view class="daily-body">
          <view class="daily-stat">
            <text class="daily-stat-label">收入</text>
            <text class="daily-stat-value">¥{{item.income}}</text>
          </view>
          <view class="daily-stat">
            <text class="daily-stat-label">成本</text>
            <text class="daily-stat-value">¥{{item.cost}}</text>
          </view>
          <view class="daily-stat">
            <text class="daily-stat-label">利润</text>
            <text class="daily-stat-value profit-text">¥{{item.profit}}</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state" style="padding: 40rpx;">
      <text class="empty-icon">📊</text>
      <text class="empty-text">暂无交易记录</text>
    </view>
  </view>

  <!-- 热门服务 -->
  <view class="card animate-in">
    <view class="card-title">热门服务</view>
    <view wx:if="{{topServices.length > 0}}">
      <view class="service-rank" wx:for="{{topServices}}" wx:key="name">
        <view class="rank-badge {{index < 3 ? 'top' : ''}}">{{index + 1}}</view>
        <view class="rank-info">
          <text class="rank-name">{{item.name}}</text>
          <text class="rank-count">{{item.count}} 次</text>
        </view>
        <text class="rank-amount">¥{{item.amount}}</text>
      </view>
    </view>
    <view wx:else class="empty-state" style="padding: 40rpx;">
      <text class="empty-icon">💅</text>
      <text class="empty-text">暂无服务记录</text>
    </view>
  </view>

  <!-- 美甲师业绩 -->
  <view class="card animate-in">
    <view class="card-title">美甲师业绩</view>
    <view wx:if="{{artistStats.length > 0}}">
      <view class="artist-stat" wx:for="{{artistStats}}" wx:key="name">
        <view class="artist-info">
          <view class="artist-avatar">{{item.name[0]}}</view>
          <text class="artist-name">{{item.name}}</text>
        </view>
        <view class="artist-data">
          <view class="artist-data-item">
            <text class="artist-data-value">{{item.count}}</text>
            <text class="artist-data-label">单</text>
          </view>
          <view class="artist-data-item">
            <text class="artist-data-value">¥{{item.amount}}</text>
            <text class="artist-data-label">业绩</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state" style="padding: 40rpx;">
      <text class="empty-icon">👩‍🎨</text>
      <text class="empty-text">暂无业绩数据</text>
    </view>
  </view>
</view>
