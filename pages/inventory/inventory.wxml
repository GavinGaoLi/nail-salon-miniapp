<!--库存管理页面-->
<view class="container">
  <!-- 搜索和筛选 -->
  <view class="search-bar">
    <text>🔍</text>
    <input placeholder="搜索产品名称" value="{{searchKey}}" bindinput="onSearch" />
  </view>

  <!-- 分类筛选 -->
  <scroll-view scroll-x class="category-scroll">
    <view class="category-chip {{currentCategory === '' ? 'active' : ''}}" bindtap="filterCategory" data-category="">全部</view>
    <view class="category-chip {{currentCategory === item ? 'active' : ''}}" 
          wx:for="{{categories}}" wx:key="*this"
          bindtap="filterCategory" data-category="{{item}}">
      {{item}}
    </view>
  </scroll-view>

  <!-- 库存统计 -->
  <view class="stats-bar">
    <view class="stat-chip">
      <text class="stat-chip-value">{{inventory.length}}</text>
      <text class="stat-chip-label">产品种类</text>
    </view>
    <view class="stat-chip">
      <text class="stat-chip-value">{{totalValue}}</text>
      <text class="stat-chip-label">库存总值</text>
    </view>
    <view class="stat-chip warning">
      <text class="stat-chip-value">{{lowStockCount}}</text>
      <text class="stat-chip-label">库存预警</text>
    </view>
  </view>

  <!-- 库存列表 -->
  <view wx:if="{{filteredInventory.length > 0}}">
    <view class="inventory-card animate-in" wx:for="{{filteredInventory}}" wx:key="id">
      <view class="inventory-header">
        <view class="inventory-info">
          <text class="inventory-name">{{item.name}}</text>
          <text class="inventory-category">{{item.category}}</text>
        </view>
        <view class="stock-badge {{item.quantity <= item.minStock ? 'low' : 'normal'}}">
          {{item.quantity <= item.minStock ? '库存不足' : '库存充足'}}
        </view>
      </view>
      <view class="inventory-body">
        <view class="inventory-row">
          <view class="inventory-stat">
            <text class="stat-label">库存数量</text>
            <text class="stat-value {{item.quantity <= item.minStock ? 'text-danger' : ''}}">{{item.quantity}} {{item.unit}}</text>
          </view>
          <view class="inventory-stat">
            <text class="stat-label">成本价</text>
            <text class="stat-value">¥{{item.costPrice}}</text>
          </view>
          <view class="inventory-stat">
            <text class="stat-label">销售价</text>
            <text class="stat-value">¥{{item.sellPrice}}</text>
          </view>
        </view>
      </view>
      <view class="inventory-actions">
        <view class="action-btn add-btn" bindtap="showStockModal" data-id="{{item.id}}" data-action="add">入库</view>
        <view class="action-btn reduce-btn" bindtap="showStockModal" data-id="{{item.id}}" data-action="reduce">出库</view>
        <view class="action-btn edit-btn" bindtap="editItem" data-id="{{item.id}}">编辑</view>
      </view>
    </view>
  </view>
  <view wx:else class="empty-state">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无库存记录</text>
  </view>

  <!-- 添加产品浮动按钮 -->
  <view class="fab" bindtap="showAddModal">
    <text>+</text>
  </view>

  <!-- 入库/出库弹窗 -->
  <view class="modal-mask" wx:if="{{showStockChange}}" bindtap="hideStockModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">{{stockAction === 'add' ? '入库' : '出库'}}</view>
      <view class="stock-change-info">
        <text class="stock-item-name">{{stockChangeItem.name}}</text>
        <text class="stock-current">当前库存: {{stockChangeItem.quantity}} {{stockChangeItem.unit}}</text>
      </view>
      <view class="form-group">
        <text class="form-label">{{stockAction === 'add' ? '入库' : '出库'}}数量</text>
        <input class="form-input" type="number" placeholder="请输入数量" value="{{stockChangeAmount}}" bindinput="onStockChangeInput" />
      </view>
      <view class="modal-actions">
        <button class="btn-secondary" bindtap="hideStockModal">取消</button>
        <button class="btn-primary" bindtap="confirmStockChange">确认</button>
      </view>
    </view>
  </view>

  <!-- 添加/编辑产品弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">{{editingId ? '编辑产品' : '添加产品'}}</view>
      
      <view class="form-group">
        <text class="form-label">产品名称</text>
        <input class="form-input" placeholder="请输入产品名称" value="{{form.name}}" bindinput="onFormInput" data-field="name" />
      </view>

      <view class="form-group">
        <text class="form-label">产品分类</text>
        <picker mode="selector" range="{{categoryOptions}}" value="{{selectedCategoryIndex}}" bindchange="onCategorySelect">
          <view class="form-picker">
            <text>{{form.category || '请选择分类'}}</text>
            <text class="arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-group">
        <text class="form-label">单位</text>
        <picker mode="selector" range="{{unitOptions}}" value="{{selectedUnitIndex}}" bindchange="onUnitSelect">
          <view class="form-picker">
            <text>{{form.unit || '请选择单位'}}</text>
            <text class="arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-row">
        <view class="form-group half">
          <text class="form-label">成本价</text>
          <input class="form-input" type="digit" placeholder="¥" value="{{form.costPrice}}" bindinput="onFormInput" data-field="costPrice" />
        </view>
        <view class="form-group half">
          <text class="form-label">销售价</text>
          <input class="form-input" type="digit" placeholder="¥" value="{{form.sellPrice}}" bindinput="onFormInput" data-field="sellPrice" />
        </view>
      </view>

      <view class="form-row">
        <view class="form-group half">
          <text class="form-label">库存数量</text>
          <input class="form-input" type="number" placeholder="数量" value="{{form.quantity}}" bindinput="onFormInput" data-field="quantity" />
        </view>
        <view class="form-group half">
          <text class="form-label">最低库存</text>
          <input class="form-input" type="number" placeholder="预警值" value="{{form.minStock}}" bindinput="onFormInput" data-field="minStock" />
        </view>
      </view>

      <view class="modal-actions">
        <button class="btn-secondary" bindtap="hideModal">取消</button>
        <button class="btn-primary" bindtap="saveItem">保存</button>
      </view>
    </view>
  </view>
</view>
