<view class="page">
  <view class="card menu-card">
    <view class="menu-item">
      <text class="mi-label">店铺名称</text>
      <text class="mi-value">{{shopName}}</text>
    </view>
    <view class="menu-item">
      <text class="mi-label">联系电话</text>
      <text class="mi-value">{{phone}}</text>
    </view>
    <view class="menu-item">
      <text class="mi-label">营业时间</text>
      <text class="mi-value">{{businessHours}}</text>
    </view>
    <view class="menu-item">
      <text class="mi-label">店铺地址</text>
      <text class="mi-value">{{address}}</text>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="changePassword">
      <text class="mi-label">修改密码</text>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearData">
      <text class="mi-label">清除数据</text>
      <text class="mi-arrow">›</text>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="about">
      <text class="mi-label">关于</text>
      <text class="mi-value">v1.0.0</text>
    </view>
  </view>

  <view class="logout-btn" bindtap="logout">退出登录</view>
</view>